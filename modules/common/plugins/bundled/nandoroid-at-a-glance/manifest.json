{
  "id": "nandoroid_at_a_glance", "name": "Nandoroid At a Glance", "description": "Expressive greeting, date, schedule, and rotating quote widget", "version": "1.0.0-port1", "apiVersion": 1,
  "author": "na-ive / nandoroid-shell", "license": "AGPL-3.0", "sourceUrl": "https://github.com/na-ive/nandoroid-shell", "upstreamRevision": "4994e2d2a264a015d5a6dac4786c60cfe94e5d8a",
  "capabilities": ["desktop-widget"], "permissions": ["filesystem_read", "settings_read", "settings_write"],
  "options": [
    { "key": "showGreeting", "type": "boolean", "label": "Show greeting", "icon": "waving_hand", "default": true },
    { "key": "showDate", "type": "boolean", "label": "Show date", "icon": "calendar_today", "default": true },
    { "key": "showEvents", "type": "boolean", "label": "Show schedule events", "icon": "event", "default": true },
    { "key": "showQuote", "type": "boolean", "label": "Show quotes", "icon": "format_quote", "default": true },
    { "key": "alignment", "type": "choice", "label": "Content alignment", "icon": "format_align_left", "default": "left", "choices": [
      { "displayName": "Left", "value": "left" }, { "displayName": "Center", "value": "center" }, { "displayName": "Right", "value": "right" }
    ]},
    { "key": "fontSize", "type": "number", "label": "Greeting size", "icon": "format_size", "default": 24, "from": 14, "to": 48, "step": 1 }
  ],
  "desktopWidget": { "component": "Widget.qml", "blur": false }
}
